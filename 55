def generate_token_and_call_api(api_key, client_app_name, prompt):
    service_name = "chat"
    url = ("https://api-ai-bridge.st.com/chatgpt/api/client-apps")

    timestamp = int(time.time())
    nonce = random.randint(100000,999999)
    data = (f"{client_app_name}_"f"{service_name}_"f"{api_key}_"f"{timestamp}_"f"{nonce}")
    hash_object = hashlib.sha1(data.encode())
    token = hash_object.hexdigest()

    request_body = {

        "version": 1,
        "clientAppName": client_app_name,
        "service": service_name,
        "timestamp": timestamp,

        "messages": [
            {
                "role": "user",
                "content": prompt
            }
        ],

        "temperature": 0,
        "persona": "st_copilot",

        
        "responseFormat": "text"
    }

    try:

        response = requests.post(

            url,

            json=request_body,

            headers={

                "stchatgpt-auth-token":
                    token,

                "stchatgpt-auth-nonce":
                    str(nonce)

            },

            verify=False,

            timeout=180
        )

        response.raise_for_status()
        response_json = response.json()
        content = response_json.get("completion", "")

        
        # Retry once if empty
        if not content:

            print("\nLLM returned empty response.")
            print("Retrying once again...\n")
            time.sleep(2)
            
            timestamp = int(time.time())
            nonce = random.randint(100000,999999)
            data = (f"{client_app_name}_"f"{service_name}_"f"{api_key}_"f"{timestamp}_"f"{nonce}")
            hash_object = hashlib.sha1(data.encode())
            token = hash_object.hexdigest()

            response = requests.post(
                url,
                json=request_body,
                headers={
                    "stchatgpt-auth-token": token,
                    "stchatgpt-auth-nonce": str(nonce)
                },
                verify=False,
                timeout=180
            )

            response.raise_for_status()
            response_json = response.json()

            content = response_json.get("completion", "")

            if not content:
                print("\nLLM still returned empty response.")

                print(response_json)

                return

        print("\nResponse length:",len(content))
        print(content)
        return content
        #save_markdown_table_as_csv(content)
        #save_readable_html_report(content)

    except requests.exceptions.RequestException as error:

        if error.response is not None:

            print("\nError:", error.response.text)

        else:

            print("\nError:", error)

def convert_csv_to_text(csv_file_path):

    """
    Read impacted_view_report.csv
    and convert only:
    CAD view, Impact
    into text format for LLM.
    """

    import csv

    lines = []

    try:

        with open(csv_file_path, "r") as csv_file:

            reader = csv.DictReader(csv_file)

            for row in reader:

                cad_view = row["CAD view"].strip()

                impact = row["Impact"].strip()

                lines.append(
                    f"{cad_view}, {impact}"
                )

        csv_to_text = "\n".join(lines)

        print("\nCSV converted to text:\n")

        print(csv_to_text)

        return csv_to_text

    except Exception as e:

        print(
            "\nError converting CSV to text:",
            e
        )

        return ""


