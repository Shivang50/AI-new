def generate_token_and_call_api(
    api_key,
    client_app_name,
    prompt
):

    service_name = "chat"

    url = (
        "https://api-ai-bridge.st.com/chatgpt/api/client-apps"
    )

    timestamp = int(time.time())

    nonce = random.randint(
        100000,
        999999
    )

    data = (
        f"{client_app_name}_"
        f"{service_name}_"
        f"{api_key}_"
        f"{timestamp}_"
        f"{nonce}"
    )

    hash_object = hashlib.sha1(
        data.encode()
    )

    token = hash_object.hexdigest()

    request_body = {

        "version": 1,
        "clientAppName": client_app_name,
        "service": service_name,
        "timestamp": timestamp,

        "messages": [
            {
                "role": "user",
                "content": prompt
            }
        ],

        "temperature": 1,
        "persona": "st_copilot",

        "responseFormat": "text"
    }

    # File paths
    topcell_csv_path = Path.cwd() / "Cell_Diff" / "topcell_diff_report.csv"
    terminal_csv_path = Path.cwd() / "terminal_diff_report.csv"

    # Validate files exist
    if not topcell_csv_path.is_file():
        raise RuntimeError(
            f"Topcell CSV not found: {topcell_csv_path}"
        )

    if not terminal_csv_path.is_file():
        raise RuntimeError(
            f"Terminal CSV not found: {terminal_csv_path}"
        )

    try:

        with open(topcell_csv_path, "rb") as f_topcell, \
             open(terminal_csv_path, "rb") as f_terminal:

            files_payload = {
                "topcell_diff_report": (
                    "topcell_diff_report.csv",
                    f_topcell,
                    "text/csv"
                ),
                "terminal_diff_report": (
                    "terminal_diff_report.csv",
                    f_terminal,
                    "text/csv"
                )
            }

            response = requests.post(

                url,

                data={
                    "payload": str(request_body)
                },

                files=files_payload,

                headers={

                    "stchatgpt-auth-token":
                        token,

                    "stchatgpt-auth-nonce":
                        str(nonce)

                },

                verify=False,

                timeout=180
            )

            response.raise_for_status()

            response_json = response.json()

            content = response_json.get(
                "completion",
                ""
            )

            # Retry once if empty

            if not content:

                print(
                    "\nLLM returned empty response."
                )

                print("Retrying once...\n")

                time.sleep(2)

                response = requests.post(

                    url,

                    data={
                        "payload": str(request_body)
                    },

                    files=files_payload,

                    headers={

                        "stchatgpt-auth-token":
                            token,

                        "stchatgpt-auth-nonce":
                            str(nonce)

                    },

                    verify=False,

                    timeout=180
                )

                response.raise_for_status()

                response_json = response.json()

                content = response_json.get(
                    "completion",
                    ""
                )

                if not content:

                    print(
                        "\nLLM still returned empty response."
                    )

                    print(response_json)

                    return

        print(
            "\nResponse length:",
            len(content)
        )

        print(content[:1000])

        save_markdown_table_as_csv(
            content
        )

    except requests.exceptions.RequestException as error:

        if error.response is not None:

            print(
                "\nError:",
                error.response.text
            )

        else:

            print(
                "\nError:",
                error
            )
