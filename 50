def convert_csv_to_text(csv_file_path):

    import csv

    rows = []

    with open(csv_file_path, "r") as f:

        reader = csv.DictReader(f)

        for row in reader:

            cad_view = row["CAD view"].strip()
            impact = row["Impact"].strip()

            rows.append(
                f"{cad_view}, {impact}"
            )

    csv_to_text = "\n".join(rows)

    return csv_to_text


