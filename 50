}


def agent_decision_engine(csv_to_text):

    print("\nAgent started processing...\n")

    lines = csv_to_text.split("\n")

    for line in lines:

        parts = line.split(",")

        if len(parts) != 2:
            continue

        cad_view = parts[0].strip()
        impact = parts[1].strip()

        print(
            f"Checking: {cad_view} → {impact}"
        )

        if impact.lower() == "yes":

            action_function = CAD_VIEW_ACTIONS.get(
                cad_view
            )

            if action_function:

                action_function()


def run_agent(csv_file_path):

    csv_to_text = convert_csv_to_text(
        csv_file_path
    )

    agent_decision_engine(
        csv_to_text
    )


if __name__ == "__main__":

    csv_file = "Output/impacted_view_report.csv"

    run_agent(csv_file)

