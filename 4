def read_user_template():
    """
    Ensures 'user_template' exists in current working directory.
    If not, prompts user for values and creates it.

    Then reads and validates required fields and returns a dict:
        {
            "Product_name": "<value>",
            "MAT10_version": "<value>",
            "BE_version or MAT10_2_version": "<value>"
        }

    Raises ValueError if something is missing or invalid.
    """

    cwd = os.getcwd()
    filepath = os.path.join(cwd, TEMPLATE_FILENAME)

    # 1. If file missing, prompt user and create it
    if not os.path.isfile(filepath):
        prompt_user_and_create_template(filepath)

    # 2. Read file and extract key-value pairs
    values = {}
    with open(filepath, "r", encoding="utf-8") as f:
        for raw_line in f:
            line = raw_line.strip()
            if not line:
                continue  # ignore empty lines

            if ":" not in line:
                continue  # ignore malformed lines (no colon)

            key_part, value_part = line.split(":", 1)
            key = key_part.strip()
            value = value_part.strip()

            if key in REQUIRED_KEYS:
                values[key] = value

    # 3. Validate presence of all required keys
    missing_keys = [k for k in REQUIRED_KEYS if k not in values]
    if missing_keys:
        raise ValueError(
            "Missing required fields in 'user_template': "
            + ", ".join(missing_keys)
            + "\nExpected lines in the file:\n"
              "Product_name:<your_product_name>\n"
              "MAT10_version:<your_mat10_version>\n"
              "BE_version or MAT10_2_version:<your_be_or_mat10_2_version>"
        )

    # 4. Validate non-empty values
    empty_keys = [k for k, v in values.items() if v == ""]
    if empty_keys:
        raise ValueError(
            "The following fields are present but empty in 'user_template': "
            + ", ".join(empty_keys)
            + "\nMake sure each line is in the form:\n"
              "Product_name:abcdef_123\n"
              "MAT10_version:1.0.12-1\n"
              "BE_version or MAT10_2_version:13-1.0.12"
        )

    return values


