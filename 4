        raise RuntimeError(
            "Failed to run dssc query.\n"
            f"Command: {shell_rep}\n"
            f"stdout:\n{result.stdout}\n"
            f"stderr:\n{result.stderr}"
        )
    print("Replication completed")



def wait_for_replication(product_name: str, version: str, check_interval: int = 60, timeout: int = 1800):
   

    start_time = time.time()

    print(
        f"\nReplication check: NOT FOUND in '{UPT_BASE}' "
        f"for product '{product_name}', version '{version}'."
    )

    

    print(
        "\nWaiting for replication to complete..."
    )

    while True:

        # Check again
        if replication_check(product_name, version):

            print(
                f"\nReplication completed successfully for "
                f"'{product_name}' version '{version}'."
            )

            return

        elapsed = int(time.time() - start_time)

        if elapsed >= timeout:

            raise RuntimeError(
                f"Timeout: replication not completed after "
                f"{timeout // 60} minutes for "
                f"{product_name} {version}"
            )

        remaining = timeout - elapsed

        print(
            f"Still waiting... "
            f"checked after {elapsed // 60} minute(s). "
            f"Next check in {check_interval} seconds."
        )

        time.sleep(check_interval)




