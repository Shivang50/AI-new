    print("gen_setup completed")




def run_dssc_query(product_name: str, outlog_path: str):
    """
    Run the required shell commands:
      1. source /work/uptplus/uptplus.csh 1
      2. dssc uptplus query ... -outputfile out.log

    The 'source' must be in the same shell as 'dssc', so we use
    one shell command string.
    """
    # Build the dssc command using the given product_name
    dssc_cmd = (
        'dssc uptplus query '
        '-type "Product Deliverable|Target Version" '
        f'-where "NAME={product_name}" '
        '-format csv '
        '-select "NAME,REVISION" '
        f'-outputfile "{outlog_path}"'
    )

    # Full shell command: source env, then run dssc
    shell_cmd = (
        'source /work/uptplus/uptplus.csh 1; '
        + dssc_cmd
    )

    # Run in a csh-compatible shell; if your environment uses bash, adapt accordingly.
    # Using shell=True so that 'source' works (it's a shell built-in).
    result = subprocess.run(
        shell_cmd,
        shell=True,
        executable="/bin/csh",  # adjust if needed (e.g. "/bin/tcsh")
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        text=True,
    )

    if result.returncode != 0:
        raise RuntimeError(
            "Failed to run dssc query.\n"
            f"Command: {shell_cmd}\n"
            f"stdout:\n{result.stdout}\n"
            f"stderr:\n{result.stderr}"
        )


def validate_product_and_version_with_outlog(product_name: str, version: str, outlog_path: str):
    """
    Read out.log (CSV: NAME,REVISION) and verify that:
      - product_name exists as NAME
      - version matches at least one REVISION for that NAME

    Raises ValueError with a clear error message if validation fails.
    """
    if not os.path.isfile(outlog_path):
        raise ValueError(
            f"'{OUTLOG_FILENAME}' not found after running dssc query. "
            "Cannot validate Product_name and version."
        )

    matching_revisions = set()
    any_name_match = False

    with open(outlog_path, "r", encoding="utf-8") as f:
        for i, line in enumerate(f):
            line = line.strip()
            if not line:
                continue

            # Skip header line if present
            if i == 0 and line.upper().startswith("NAME,REVISION"):
                continue

            parts = line.split(",")
            if len(parts) < 2:
                continue  # malformed line, skip

            name = parts[0].strip()
            revision = parts[1].strip()

            if name == product_name:
                any_name_match = True
                matching_revisions.add(revision)

    # Check Product_name present
    if not any_name_match:
        raise ValueError(
            f"Product_name '{product_name}' from '{TEMPLATE_FILENAME}' "
            f"does not match any NAME entry in '{OUTLOG_FILENAME}'."
        )

    # Check MAT10_version matches one of the revisions
    if version not in matching_revisions:
        raise ValueError(
            f"version '{version}'"
            "is not present in uptplus for Product_name "
            f"'{product_name}'.\n"
            f"Available versions for this product: "
            + (", ".join(sorted(matching_revisions)) if matching_revisions else "<none>")
        )

def replication_check(product_name: str, version: str) -> bool:
    rep_path = os.path.join(UPT_BASE, product_name, version)
    return os.path.isdir(rep_path)

