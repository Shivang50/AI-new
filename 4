def parse_bbview(vc_path: Path):
    if not vc_path.is_file():
        raise RuntimeError(f"vc.bbview not found: {vc_path}")
    libname = None
    topcell = []
    in_cells_block = False

    with vc_path.open("r", encoding="utf-8") as f:
        for raw in f:
            line = raw.strip()
            if not line:
                continue

            if line.startswith("LIBRARY "):
                parts = line.split()
                if len(parts) >= 2:
                    libname = parts[1]
                continue

            if line == "CELLS":
                in_cells_block = True
                continue

            if line == "END":
                in_cells_block = False
                continue

            if in_cells_block:
                cell_name = line.split()[0]
                topcell.append(cell_name)

        if libname is None:
            raise RuntimeError(f"No LIBRARY name found in {vc_path}")
        if not topcell:
            raise RuntimeError(f"No cells found in CELLS block in {vc_path}")

        return libname, topcell

