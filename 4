def read_terminals(file_path: Path) -> set[str]:
    with file_path.open("r", encoding="utf-8") as f:
        return {line.strip() for line in f if line.strip()}


def find_cell_pairs(input_dir: Path):
    pairs = []
    be_files = list(input_dir.glob(f"*{BE_SUFFIX}"))

    for be_file in be_files:
        cell_name = be_file.name[: -len(BE_SUFFIX)]
        mat_file = input_dir / f"{cell_name}{MAT10_SUFFIX}"
        if mat_file.exists():
            pairs.append((cell_name, be_file, mat_file))
        else:
            print(f"WARNING: MAT file not found for cell '{cell_name}': {mat_file}")

    return pairs


def compare_terminals(be_file: Path, mat_file: Path):
    be_terms = read_terminals(be_file)
    mat_terms = read_terminals(mat_file)

    # Option A:
    # Added   = present in BE, absent in MAT
    # Removed = present in MAT, absent in BE
    added = sorted(be_terms - mat_terms)
    removed = sorted(mat_terms - be_terms)

    return added, removed


def write_csv(rows, output_csv: Path):
    with output_csv.open("w", newline="", encoding="utf-8") as f:
        writer = csv.writer(f)
        writer.writerow(["Cell Name", "Terminals Added", "Terminals Removed"])
        writer.writerows(rows)


