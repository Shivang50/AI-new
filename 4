def write_setuplog_topcell_list(libpath2: str):
    search_paths = [
        Path(libpath2) / "SETUPLOG" / "cell.list",
        Path(libpath2) / "SETUPLOG" / "topcell.list",
        Path(libpath2) / "SETUPLOG" / "CELLS" / "topcell.list",
        Path(libpath2) / "SETUPLOG" / "REF_FILES" / "topcell.list",
        Path(libpath2) / "SETUPLOG" / "REF_FILES" / "cell.list"
    ]

    source_file = None
    for p in search_paths:
        if p.is_file():
            source_file = p
            break

    if source_file is None:
        print(
            "WARNING: No topcell list file found in any of the expected paths in SETUPLOG."
        )
        output_file = Path.cwd() / "SETUPLOG_topcell.list"
        output_file.write_text("", encoding="utf-8")
        return [], output_file, None

    output_file = Path.cwd() / "SETUPLOG_topcell.list"

    contents = source_file.read_text(encoding="utf-8")
    output_file.write_text(contents, encoding="utf-8")

    # Also parse the list into Python
    cells = []
    with source_file.open("r", encoding="utf-8") as f:
        for raw in f:
            line = raw.strip()
            if line:
                cells.append(line)

    unique_cells = sorted(set(cells))

    print(f"Selected source file: {source_file}")
    print(f"Wrote BE topcell list to: {output_file}")
    print(f"Found {len(unique_cells)} topcells in BE")

    return unique_cells, output_file, source_file

def compare_cell_lists(reference_cells, candidate_cells):
    ref_set = set(reference_cells)
    cand_set = set(candidate_cells)

    added = sorted(cand_set - ref_set)
    removed = sorted(ref_set - cand_set)

    return {
        "cells_added": added,
        "removed": removed

    }

