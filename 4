def load_ucdprod_env():
    script_dir = Path(__file__).resolve().parent

    csh_cmd = f"""
        cd "{script_dir}"
        setenv UCDPRJDIR $PWD
        eval `ukerEnv`
        if ($status != 0) then
            echo "ERROR: eval `ukerEnv` failed" >&2
            exit 1
        endif
        echo "ucdprod environment loaded successfully."
        env
    """

    try:
        result = subprocess.run(
            ["csh", "-c", csh_cmd],
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )
    except subprocess.CalledProcessError as e:
        print("Failed to load ucdprod environment.")
        if e.stderr:
            print("stderr from csh:\n", e.stderr)
        sys.exit(1)

    stdout_lines = result.stdout.splitlines()
    if stdout_lines:
        # First line is our success message
        print(stdout_lines[0])

    # Remaining lines: KEY=VALUE
    for line in stdout_lines[1:]:
        if "=" in line:
            key, value = line.split("=", 1)
            os.environ[key] = value


def get_basic_lib_path():
    """
    Implements:
      virtuosoPath=`which virtuoso | cut -d"/" -f1,2,3,4,5,6`
      basicLibPath="$virtuosoPath/tools.lnx86/dfII/etc/cdslib/basic"
    Returns the full basicLibPath string, or None if virtuoso is not found.
    """
	
	
    try:
        which_res = subprocess.run(
            ["bash", "-c", "which virtuoso"],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            check=True,
        )
        virtuoso_full = which_res.stdout.strip()
        if not virtuoso_full:
            return None
    except subprocess.CalledProcessError:
        return None

    try:
        cut_res = subprocess.run(
            ["bash", "-c", f'echo "{virtuoso_full}" | cut -d"/" -f1,2,3,4,5,6'],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            check=True,
        )
        virtuoso_path = cut_res.stdout.strip()
        if not virtuoso_path:
            return None
    except subprocess.CalledProcessError:
        return None

    return f"{virtuoso_path}/tools.lnx86/dfII/etc/cdslib/basic"


def build_three_lines(libname: str, libpath_for_third: str, add_xorlib: bool = False):
    """
    Build the lines that must be written to cds file:
      1) SOFTINCLUDE <DKITROOT>/<something>.cdslib
      2) DEFINE basic <basicLibPath>
      3) DEFINE <libname> <libpath_for_third>/CADENCE/CDSOA or OA
      4) DEFINE XORLIB <cwd>/XORLIB   [optional]
    """
    dkitroot = os.environ.get("DKITROOT")
    if not dkitroot:
        raise RuntimeError("DKITROOT is not set in the environment.")

    pattern = os.path.join(dkitroot, "*.cdslib")
    matches = glob.glob(pattern)

    if not matches:
        raise RuntimeError(f"No .cdslib file found under DKITROOT: {pattern}")

    cdslib_path = matches[0]
    soft_line = f"SOFTINCLUDE {cdslib_path}\n"

    basic_lib_path = get_basic_lib_path()
    if not basic_lib_path:
        raise RuntimeError("Could not determine virtuoso path (basicLibPath).")
    basic_line = f"DEFINE basic {basic_lib_path}\n"

    cdsoa_path = os.path.join(libpath_for_third, "CADENCE", "CDSOA")
    oa_path = os.path.join(libpath_for_third, "OA")

    if os.path.isdir(cdsoa_path):
        third_target = cdsoa_path
    elif os.path.isdir(oa_path):
        third_target = oa_path
    else:
        raise RuntimeError("Could not find valid directory structure")

    third_line = f"DEFINE {libname} {third_target}\n"

    lines = [soft_line, basic_line, third_line]

    if add_xorlib:
        xorlib_path = str(Path.cwd() / "XORLIB")
        xor_line = f"DEFINE XORLIB {xorlib_path}\n"
        lines.append(xor_line)

    return lines

def get_techlib():
    script_dire = Path(__file__).resolve().parent #dir->dire, csh_cmd->csh_cmmd
 
    dkitroot = os.environ.get("DKITROOT")
    if not dkitroot:
        raise RuntimeError("PDK not set in environment")
 
    csh_cmmd = f"""
        cd "{script_dire}"
        setenv UCDPRJDIR $PWD
        eval `ukerEnv`
        if ($status != 0) then
            echo "ERROR: eval `ukerEnv` failed" >&2
            exit 1
        endif
 
        if (! $?DKITROOT) then
            echo "ERROR: DKITROOT not set after ukerEnv" >&2
            exit 1
        endif
 
        set techlib = `piGetInfo "{dkitroot}/" processLibName`
        if ($status != 0) then
            echo "ERROR: piGetInfo failed" >&2
            exit 1
        endif
        echo "$techlib"
    """
 
    try:
        result = subprocess.run(
            ["csh", "-c", csh_cmmd],
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )
    except subprocess.CalledProcessError as e:
        raise RuntimeError(
            "Failed to get techlib via piGetInfo.\n"
            f"STDOUT:\n{e.stdout}\n"
            f"STDERR:\n{e.stderr}"
        ) from e
 
    lines = [ln.strip() for ln in result.stdout.splitlines() if ln.strip()]
    if not lines:
        raise RuntimeError(
            "piGetInfo returned an empty techlib.\n"
            f"STDOUT:\n{result.stdout}\n"
            f"STDERR:\n{result.stderr}"
        )
 
    return lines[-1]

def overwrite_cds_lib(cds_lib_path: str, libname: str, libpath_for_third: str, add_xorlib: bool = False):
    """Completely overwrite the file (create it if it does not exist)."""
	
    lines = build_three_lines(libname, libpath_for_third, add_xorlib=add_xorlib)

    dir_name = os.path.dirname(cds_lib_path)
    if dir_name:  # if file is in a subdirectory, ensure it exists
        os.makedirs(dir_name, exist_ok=True)

    with open(cds_lib_path, "w") as f:
        f.writelines(lines)

