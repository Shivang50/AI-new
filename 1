# Read, filter, sort LPP lines
def read_diff_lines_from_log(file_path="Output/report.log"):

    unique_lpps = set()

    try:

        diff_dir = os.path.join(os.getcwd(), "Diff_Logs")
        full_path = os.path.join(os.getcwd(), file_path)

        if not os.path.exists(full_path):

            print(
                f"Error: {file_path} not found "
                "in current directory."
            )

            sys.exit(1)

        pattern = re.compile(
            r'difference[s]?\s+on\s+lpp\s*:\s*\("([^"]+)"\s+"([^"]+)"\)',
            re.IGNORECASE
        )

        with open(full_path, "r") as file:

            for line in file:

                line = line.strip()

                match = pattern.search(line)

                if match:

                    layer = match.group(1).strip()
                    purpose = match.group(2).strip()

                    # Exclude instance drawing
                    if (
                        layer.lower() == "instance"
                        and purpose.lower() == "drawing"
                    ):
                        continue

                    unique_lpps.add(
                        (layer, purpose)
                    )

        if not unique_lpps:

            print(
                "No valid LPP differences found."
            )

            sys.exit(1)

        sorted_lpps = sorted(unique_lpps)

        diff_lines = [

            f'difference on lpp:("{layer}" "{purpose}")'

            for layer, purpose
            in sorted_lpps
        ]

        print(
            "\nTotal unique LPPs:",
            len(diff_lines)
        )

        print("\nLPPs being sent to LLM:\n")

        for lpp in diff_lines:
            print(lpp)

        return diff_lines

    except Exception as e:

        print(
            "Error reading log file:",
            e
        )

        sys.exit(1)




