# Generate token and call API

def generate_token_and_call_api(
    api_key,
    client_app_name,
    prompt
):

    service_name = "chat"

    url = (
        "https://api-ai-bridge.st.com/chatgpt/api/client-apps"
    )

    timestamp = int(time.time())

    nonce = random.randint(
        100000,
        999999
    )

    data = (
        f"{client_app_name}_"
        f"{service_name}_"
        f"{api_key}_"
        f"{timestamp}_"
        f"{nonce}"
    )

    hash_object = hashlib.sha1(
        data.encode()
    )

    token = hash_object.hexdigest()


    request_body = {

        "version": 1,
        "clientAppName": client_app_name,
        "service": service_name,
        "timestamp": timestamp,

        "messages": [
            {
                "role": "user",
                "content": prompt
            }
        ],

        "temperature": 1,
        "persona": "st_copilot",

        
        "responseFormat": "text"
    }

    try:

        response = requests.post(

            url,

            json=request_body,

            headers={

                "stchatgpt-auth-token":
                    token,

                "stchatgpt-auth-nonce":
                    str(nonce)

            },

            verify=False,

            timeout=180
        )

        response.raise_for_status()

        response_json = response.json()

        content = response_json.get(
            "completion",
            ""
        )

        
        # Retry once if empty
        

        if not content:

            print(
                "\nLLM returned empty response."
            )

            print("Retrying once...\n")

            time.sleep(2)

            response = requests.post(
                url,
                json=request_body,
                headers={
                    "stchatgpt-auth-token": token,
                    "stchatgpt-auth-nonce": str(nonce)
                },
                verify=False,
                timeout=180
            )

            response.raise_for_status()

            response_json = response.json()

            content = response_json.get(
                "completion",
                ""
            )

            if not content:

                print(
                    "\nLLM still returned empty response."
                )

                print(response_json)

                return

        print(
            "\nResponse length:",
            len(content)
        )

        

        print(content)

    except requests.exceptions.RequestException as error:

        if error.response is not None:

            print(
                "\nError:",
                error.response.text
            )

        else:

            print(
                "\nError:",
                error
            )




