import os
import glob
import subprocess
import sys
import urllib3
import requests
import hashlib
import random
import time
import base64

# Disable SSL warnings
urllib3.disable_warnings(
    urllib3.exceptions.InsecureRequestWarning
)


def build_prompt():

    base_prompt = (
        "Please analyze all pages of the attached PDF."
    )

    return base_prompt


def generate_token_and_call_api(
    api_key,
    client_app_name,
    prompt
):

    service_name = "chat"

    url = (
        "https://api-ai-bridge.st.com/chatgpt/api/client-apps"
    )

    timestamp = int(time.time())

    nonce = random.randint(
        100000,
        999999
    )

    data = (
        f"{client_app_name}_"
        f"{service_name}_"
        f"{api_key}_"
        f"{timestamp}_"
        f"{nonce}"
    )

    token = hashlib.sha1(
        data.encode()
    ).hexdigest()

    # =====================================
    # PDF → PNG conversion using pdftoppm
    # =====================================

    pdf_path = "/full/path/to/your/file.pdf"

    if not os.path.exists(pdf_path):

        print("PDF file not found:", pdf_path)
        return

    try:

        output_prefix = "temp_page"

        print("\nConverting PDF pages to images...")

        subprocess.run(
            [
                "/usr/bin/pdftoppm",
                "-png",
                pdf_path,
                output_prefix
            ],
            check=True
        )

        image_files = sorted(
            glob.glob("temp_page-*.png")
        )

        if not image_files:

            print("No images generated from PDF")
            return

        print(
            "Total pages converted:",
            len(image_files)
        )

        content_list = []

        # Add prompt first
        content_list.append(
            {
                "type": "text",
                "content": prompt
            }
        )

        for image_path in image_files:

            with open(
                image_path,
                "rb"
            ) as img_file:

                encoded_string = base64.b64encode(
                    img_file.read()
                ).decode("utf-8")

            image_base64 = (
                "data:image/png;base64,"
                + encoded_string
            )

            content_list.append(
                {
                    "type": "image",
                    "content": image_base64
                }
            )

    except Exception as e:

        print("PDF conversion failed:", e)
        return

    # =====================================
    # REQUEST BODY
    # =====================================

    request_body = {

        "version": 1,
        "clientAppName": client_app_name,
        "service": service_name,
        "timestamp": timestamp,

        "messages": [
            {
                "role": "user",
                "content": content_list
            }
        ],

        "temperature": 1,
        "persona": "st_copilot",
        "responseFormat": "text"
    }

    try:

        response = requests.post(

            url,

            json=request_body,

            headers={
                "stchatgpt-auth-token": token,
                "stchatgpt-auth-nonce": str(nonce)
            },

            verify=False,

            timeout=180
        )

        response.raise_for_status()

        response_json = response.json()

        content = response_json.get(
            "completion",
            ""
        )

        if not content or not content.strip():

            print(
                "\nLLM returned empty response."
            )

            print(
                "Retrying once..."
            )

            time.sleep(2)

            response = requests.post(
                url,
                json=request_body,
                headers={
                    "stchatgpt-auth-token": token,
                    "stchatgpt-auth-nonce": str(nonce)
                },
                verify=False,
                timeout=180
            )

            response.raise_for_status()

            response_json = response.json()

            content = response_json.get(
                "completion",
                ""
            )

            if not content or not content.strip():

                print(
                    "\nLLM still returned empty response."
                )

                print(
                    response_json
                )

                return

        print(
            "\nResponse length:",
            len(content)
        )

        print(
            "\nLLM Response:\n"
        )

        print(
            content
        )

    except requests.exceptions.RequestException as error:

        if error.response is not None:

            print(
                "\nError:",
                error.response.text
            )

        else:

            print(
                "\nError:",
                error
            )

    # =====================================
    # CLEANUP TEMP FILES
    # =====================================

    for file in image_files:

        if os.path.exists(file):

            os.remove(file)


if __name__ == "__main__":

    api_key = "YOUR_API_KEY"

    client_app_name = (
        "gtrd_library_cad_eda_management"
    )

    prompt = build_prompt()

    generate_token_and_call_api(
        api_key,
        client_app_name,
        prompt
    )
