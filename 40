def open_html_report(html_file_path):
    """
    Open the generated HTML report using Firefox via csh shell.
    Matches environments where commands are executed using csh.
    """

    import subprocess
    import os

    firefox_path = "/sw/freetools/firefox/92.0/rh70_64/firefox"

    if not os.path.exists(html_file_path):
        print("HTML file not found:", html_file_path)
        return

    try:
        # Build the command exactly like terminal usage
        command = f'{firefox_path} "{html_file_path}" &'

        subprocess.Popen(
            ["csh", "-c", command],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )

        print("Opened HTML report in Firefox using csh")

    except Exception as e:
        print("Failed to open HTML file:", e)



