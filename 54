def convert_csv_to_text(csv_file_path):

    """
    Read impacted_view_report.csv
    and convert only:
    CAD view, Impact
    into text format for LLM.
    """

    import csv

    lines = []

    try:

        with open(csv_file_path, "r") as csv_file:

            reader = csv.DictReader(csv_file)

            for row in reader:

                cad_view = row["CAD view"].strip()

                impact = row["Impact"].strip()

                lines.append(
                    f"{cad_view}, {impact}"
                )

        csv_to_text = "\n".join(lines)

        print("\nCSV converted to text:\n")

        print(csv_to_text)

        return csv_to_text

    except Exception as e:

        print(
            "\nError converting CSV to text:",
            e
        )

        return ""


